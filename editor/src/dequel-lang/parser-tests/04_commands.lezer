# basic command

id:oneOf(1,2,3)

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(Command(
      Identifier,
      "(",
      ArgList(
        Argument(Number),
        ",",
        Argument(Number),
        ",",
        Argument(Number)
      ),
      ")"
    )))
  )
)

# various args

id:anyFn(something,1,2)

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(Command(
      Identifier,
      "(",
      ArgList(
        Argument(Identifier),
        ",",
        Argument(Number),
        ",",
        Argument(Number)
      ),
      ")"
    )))
  )
)

