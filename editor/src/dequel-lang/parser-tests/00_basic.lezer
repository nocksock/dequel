# simple

type:markets title:EDEKA

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier))))
  )
)

# simple with snake_case

type:markets market_id:123

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Number))))
  )
)

# spaces between conditions don't matter

type:markets    title:EDEKA

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier))))
  )
)

# exclude

type:markets -title:EDEKA

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    ExcludeCondition("-", Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier))))
  )
)

# line breaks with indentation are allowed

type:markets
  title:EDEKA

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier))))
  )
)

# line breaks with multiple conditions

type:markets
  title:EDEKA
  -status:closed

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    ExcludeCondition("-", Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier))))
  )
)

# values

type:markets
  title:EDEKA
  title:"Some string"
  id:123

==>

QueryList(
  Query(
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Identifier)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(String)))),
    Condition(Field(Identifier), ":", Predicate(SimplePredicate(Value(Number))))
  )
)


